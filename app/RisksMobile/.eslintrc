{
    "env": {
        "browser": true,
        "node": true,
        "es6": true
    },
    "rules": {
        "no-undef": "error",
        "consistent-return": "warn",
        "no-unused-vars": ["warn", { "args": "none" }],
        "eqeqeq": ["error", "always"]
    },
    "parserOptions": {
        "sourceType": "module",
        "ecmaVersion": 2020
    }
}